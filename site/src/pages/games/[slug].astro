---
import { existsSync, readdirSync } from "node:fs";
import path from "node:path";
import Layout from "../../layouts/Layout.astro";
import PdfDeckViewer from "../../components/PdfDeckViewer.astro";
import { games } from "../../data/games";
import { showcaseAssets } from "../../data/showcaseAssets";
import { otherProjects } from "../../data/allProjects";
import { withBase } from "../../utils/paths";

export function getStaticPaths() {
  // Label a source link by its host so the button reads sensibly. Defined inside
  // getStaticPaths because Astro runs it in isolation from module scope.
  const sourceLabel = (url: string) => {
    if (url.includes("github.com")) return "GitHub repo";
    if (url.includes("drive.google.com")) return "Google Drive";
    if (url.includes("1drv.ms") || url.includes("onedrive")) return "OneDrive";
    if (url.includes("icloud.com")) return "iCloud";
    return "Download";
  };
  // Winners: full data (cover art, local slide PDF + source preview).
  const winnerEntries = games.map((game) => {
    const asset = showcaseAssets[game.slug] ?? { sourceFiles: [] };
    return {
      params: { slug: game.slug },
      props: {
        entry: {
          slug: game.slug,
          title: game.title,
          team: game.team,
          track: game.track,
          code: game.teamCode,
          awards: game.awards,
          summary: game.summary,
          writeup: game.writeup,
          cover: game.cover,
          playUrl: asset.playUrl ?? null,
          keyboardMode: asset.keyboardMode ?? null,
          slidePdf: asset.slidePdf ?? null,
          sourceFiles: asset.sourceFiles ?? [],
          links: game.links.map((l) => ({ label: l.label, href: l.href, external: false })),
          isWinner: true,
        },
      },
    };
  });

  // Every other entry: same page shape, but cover is a generated gradient,
  // slides/source link out to the team's own files, and the playable build
  // (if any) embeds the same way.
  const restEntries = otherProjects.map((p) => {
    const links = [];
    if (p.slides) links.push({ label: "Slides", href: p.slides, external: true });
    if (p.source) links.push({ label: sourceLabel(p.source), href: p.source, external: true });
    if (p.doc) links.push({ label: "Write-up doc", href: p.doc, external: true });
    return {
      params: { slug: p.id },
      props: {
        entry: {
          slug: p.id,
          title: p.title || p.code,
          team: p.team,
          track: p.track,
          code: p.code,
          awards: [],
          summary: p.blurb,
          writeup: p.writeup ?? p.blurb,
          cover: null,
          playUrl: p.playSlug ? `/play/${p.playSlug}/index.html` : null,
          keyboardMode: p.playSlug && p.track === "Pygame" ? "full" : null,
          slidePdf: p.slidePdf ?? null,
          sourceFiles: [],
          links,
          isWinner: false,
        },
      },
    };
  });

  return [...winnerEntries, ...restEntries];
}

const { entry } = Astro.props as { entry: any };
const isPlayable = Boolean(entry.playUrl);

// Rough download size of each playable build, shown on the click-to-load poster
// so visitors aren't surprised by a large fetch (Unity numbers are wasm + data).
const playSize: Record<string, string> = {
  u8: "~180 MB", u13: "~85 MB", u4: "~75 MB", u2: "~70 MB", u16: "~70 MB",
  u6: "~70 MB", u1: "~30 MB", u14: "~12 MB", u15a: "~23 MB", u18: "~18 MB", u11: "~23 MB", u7b: "~22 MB",
  p26: "~15 MB", p17: "~10 MB", p1: "~10 MB", p6: "~10 MB", p8: "~10 MB",
  p14: "~10 MB", p15: "~10 MB", p3: "~14 MB", p23: "~14 MB", p12: "~15 MB",
  p5: "~10 MB", p9: "~10 MB", p10: "~10 MB", p16: "~10 MB", p20: "~10 MB",
  p22: "~10 MB", p19: "~10 MB", p32: "~7 MB", u17: "~7 MB", u7a: "~15 MB", u12: "~25 MB", p28: "~1 MB", p24: "~11 MB", p4: "~1 MB", p31: "~1 MB", p27: "~44 MB", p25: "~1 MB", p29: "~10 MB", p33: "~10 MB", u10: "~10 MB",
};
// Short control hints, only for builds whose controls were confirmed.
const playControls: Record<string, string> = {
  p17: "Move WASD / arrows · Interact E · Pick specialty 1 / 2 / 3 · Ready Space",
  p8: "Advance / attack W · Special 1 · Heal 2 · Skip cutscene Space",
  p15: "Press Enter or click to advance",
  p26: "Click the on-screen buttons with the mouse",
  u4: "Move WASD · Look with the mouse · Click to interact",
  p10: "Move with WASD / arrows · pause Space or Esc",
  p5: "Click the answer buttons with the mouse",
  p19: "Move with WASD / arrows",
  p31: "Move WASD · spam Space to fight",
  p32: "Move / jump with arrows or Space",
  p25: "Click with the mouse",
  u18: "Move WASD · Interact E · Click the menu buttons",
};
const sizeLabel = playSize[entry.slug] ?? "";
const controlsHint = playControls[entry.slug] ?? "";

const tagClass = (tag: string) => {
  if (tag.includes("Winner") || tag.includes("Runner")) return "rank";
  if (tag === "Pygame" || tag === "Unity") return "track";
  return "special";
};

const getSlideImages = (slidePdf?: string | null) => {
  if (!slidePdf) return [];
  const pdfPublicPath = path.join(process.cwd(), "public", slidePdf.replace(/^\//, ""));
  const slideDir = path.dirname(pdfPublicPath);
  if (!existsSync(slideDir)) return [];
  return readdirSync(slideDir)
    .filter((file) => /^slide-\d+\.(png|jpe?g)$/i.test(file))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
    .map((file) => `${path.posix.dirname(slidePdf)}/${file}`);
};

const slideImages = getSlideImages(entry.slidePdf);

const keyboardRows =
  entry.keyboardMode === "full"
    ? [
        ["1", "2", "3", "4", "5", "6", "7", "8", "9", "0"],
        ["Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P"],
        ["A", "S", "D", "F", "G", "H", "J", "K", "L"],
        ["Z", "X", "C", "V", "B", "N", "M"],
        ["ArrowLeft", "ArrowDown", "ArrowUp", "ArrowRight"],
        ["Backspace", "Space", "Enter"],
      ]
    : entry.keyboardMode === "wasd"
      ? [["W"], ["A", "S", "D"], ["Space", "Enter"]]
      : [];

const keyLabel = (key: string) =>
  ({
    ArrowLeft: "Left",
    ArrowDown: "Down",
    ArrowUp: "Up",
    ArrowRight: "Right",
    Backspace: "Bksp",
    Space: "Space",
    Enter: "Enter",
  })[key] ?? key;

// Cover: winners have art; everyone else gets a themed gradient + title.
const coverBg = entry.cover
  ? `linear-gradient(rgba(2, 6, 23, 0.55), rgba(2, 6, 23, 0.82)), url(${withBase(entry.cover)})`
  : entry.track === "Unity"
    ? "linear-gradient(150deg, #0b2540 0%, #07112f 60%, #020617 100%)"
    : "linear-gradient(150deg, #3a1d4d 0%, #1a1033 55%, #020617 100%)";

const backHref = entry.isWinner ? withBase("/") : withBase("/all-projects/");
const backLabel = entry.isWinner ? "Back to showcase" : "Back to all projects";
---

<Layout title={entry.title} description={entry.summary}>
  <main class="container">
    <section class="section-block compact">
      <a class="button" href={backHref}>{backLabel}</a>
    </section>

    <section class="detail-hero">
      <div class:list={["detail-media", !entry.cover && "detail-media-fallback"]} style={!entry.cover ? `background:${coverBg}` : undefined}>
        {entry.cover ? <img src={withBase(entry.cover)} alt="" /> : <span class="cover-fallback">{entry.title}</span>}
      </div>
      <div class="detail-copy">
        <div class="tag-row">
          <span class={`tag ${tagClass(entry.track)}`}>{entry.track}</span>
          {entry.awards.map((award: string) => <span class={`tag ${tagClass(award)}`}>{award}</span>)}
          <span class={`tag play-state ${isPlayable ? "playable" : "pending"}`}>
            {isPlayable ? "Playable" : "Not playable"}
          </span>
        </div>
        <p class="eyebrow">{entry.code} - {entry.track}</p>
        <h1>{entry.title}</h1>
        <p class="team">{entry.team}</p>
      </div>
    </section>

    <section class:list={["detail-body", isPlayable && "detail-body-playable"]}>
      <article class="writeup">
        {entry.writeup.split(/\n\s*\n/).map((paragraph: string) => <p>{paragraph}</p>)}
      </article>

      <aside class="side-panel">
        <section class="play-panel">
          <div class="panel-heading-row">
            <p class="eyebrow">Play</p>
            <span class={`tag play-state ${isPlayable ? "playable" : "pending"}`}>
              {isPlayable ? "Playable now" : "Not playable"}
            </span>
          </div>

          {
            isPlayable ? (
              <>
                <div class="play-embed-wrap" data-embed-wrap>
                  <iframe
                    class="play-embed"
                    data-play-embed
                    data-src={withBase(entry.playUrl)}
                    title={`${entry.title} playable build`}
                    loading="lazy"
                    allow="autoplay; fullscreen; gamepad"
                    sandbox="allow-scripts allow-same-origin allow-pointer-lock allow-popups allow-forms"
                  />
                  <button
                    class="play-loader"
                    type="button"
                    data-play-loader
                    style={`background-image: ${coverBg}`}
                  >
                    <span class="play-loader-icon" aria-hidden="true">▶</span>
                    <span class="play-loader-label">Play {entry.title}</span>
                    <span class="play-loader-size">
                      Tap to load the build{sizeLabel ? ` · ${sizeLabel}` : ""}
                    </span>
                  </button>
                  <button class="embed-restart" type="button" data-embed-restart title="Restart game" hidden>
                    ↻
                  </button>
                  <button class="embed-fullscreen" type="button" data-embed-fullscreen title="Fullscreen" hidden>
                    ⛶
                  </button>
                </div>
                {controlsHint && (
                  <p class="play-controls">
                    <strong>Controls</strong>
                    <span>{controlsHint}</span>
                  </p>
                )}
                {keyboardRows.length > 0 && (
                  <div
                    class={`game-keyboard ${entry.keyboardMode === "full" ? "full-keyboard" : "wasd-keyboard"}`}
                    data-game-keyboard
                    hidden
                  >
                    <button class="focus-game" type="button" data-focus-game>
                      Focus game
                    </button>
                    <div class="key-row-stack">
                      {keyboardRows.map((row) => (
                        <div class="key-row">
                          {row.map((key) => (
                            <button class={`key-button key-${key.toLowerCase()}`} type="button" data-key={key}>
                              {keyLabel(key)}
                            </button>
                          ))}
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </>
            ) : (
              <div class="play-frame">
                <div>
                  <p class="play-title">Not playable in-browser</p>
                  <p class="play-note">
                    This entry doesn't have a browser build — grab the source or slides below to run or read it.
                  </p>
                </div>
              </div>
            )
          }
        </section>

        {
          entry.links.length > 0 && (
            <section class="links-panel">
              <p class="eyebrow">Files</p>
              <h3>Slides and source</h3>
              <div class="link-list">
                {entry.links.map((link: any) =>
                  link.external ? (
                    <a class="mini-link" href={link.href} target="_blank" rel="noopener noreferrer">
                      {link.label}
                    </a>
                  ) : (
                    <a class="mini-link" href={encodeURI(withBase(link.href))}>
                      {link.label}
                    </a>
                  )
                )}
              </div>
            </section>
          )
        }
      </aside>
    </section>

    {
      entry.slidePdf && (
        <section class="showcase-section">
          <div class="section-heading">
            <p class="eyebrow">Slides</p>
            <h2>Presentation deck</h2>
          </div>
          <PdfDeckViewer src={entry.slidePdf} title={`${entry.title} presentation`} slideImages={slideImages} />
        </section>
      )
    }

    {
      entry.sourceFiles.length > 0 && (
        <section class="showcase-section">
          <div class="section-heading">
            <p class="eyebrow">Source</p>
            <h2>Full source</h2>
          </div>
          <div class="code-grid">
            {entry.sourceFiles.map((file: any) => (
              <details class="code-panel" data-source-card data-source-url={encodeURI(withBase(file.href))}>
                <summary>
                  <div>
                    <p class="eyebrow">{file.language === "python" ? "Pygame" : "Unity C#"}</p>
                    <h3>{file.label}</h3>
                  </div>
                  <span>Toggle source</span>
                </summary>
                <div class="source-link-row">
                  <a href={encodeURI(withBase(file.href))}>Open raw source</a>
                </div>
                <pre><code data-source-code>Open this card to load source.</code></pre>
              </details>
            ))}
          </div>
        </section>
      )
    }
  </main>
</Layout>

<script>
  // @ts-nocheck
  const keyMeta = {
    ArrowLeft: { key: "ArrowLeft", code: "ArrowLeft", keyCode: 37 },
    ArrowUp: { key: "ArrowUp", code: "ArrowUp", keyCode: 38 },
    ArrowRight: { key: "ArrowRight", code: "ArrowRight", keyCode: 39 },
    ArrowDown: { key: "ArrowDown", code: "ArrowDown", keyCode: 40 },
    Backspace: { key: "Backspace", code: "Backspace", keyCode: 8 },
    Enter: { key: "Enter", code: "Enter", keyCode: 13 },
    Space: { key: " ", code: "Space", keyCode: 32 },
  };

  const getKeyMeta = (value) => {
    if (keyMeta[value]) return keyMeta[value];
    const upper = value.toUpperCase();
    return {
      key: value.length === 1 ? value.toLowerCase() : value,
      code: value.length === 1 && /[A-Z]/.test(upper) ? `Key${upper}` : value,
      keyCode: value.length === 1 ? upper.charCodeAt(0) : 0,
    };
  };

  const fireGameKey = (iframe, value, type) => {
    const targetWindow = iframe?.contentWindow;
    if (!targetWindow) return;
    const meta = getKeyMeta(value);
    const eventInit = {
      key: meta.key,
      code: meta.code,
      keyCode: meta.keyCode,
      which: meta.keyCode,
      bubbles: true,
      cancelable: true,
    };
    targetWindow.focus();
    targetWindow.dispatchEvent(new KeyboardEvent(type, eventInit));
    targetWindow.document?.dispatchEvent(new KeyboardEvent(type, eventInit));
  };

  // Only show the on-screen keyboard on touch devices that have no physical
  // keyboard (phones/tablets). On desktop the user has a real keyboard, so the
  // on-screen keys are redundant clutter — hide them and let the game take key
  // input directly once it's clicked/focused.
  const isTouchDevice =
    window.matchMedia("(hover: none) and (pointer: coarse)").matches ||
    /Android|iPhone|iPod/i.test(navigator.userAgent);

  // Click-to-load: the heavy game build is only fetched once the visitor asks,
  // so just reading the write-up or slides doesn't download tens of MB.
  document.querySelectorAll("[data-embed-wrap]").forEach((wrap) => {
    const iframe = wrap.querySelector("[data-play-embed]");
    const loader = wrap.querySelector("[data-play-loader]");
    const fullscreenButton = wrap.querySelector("[data-embed-fullscreen]");
    const restartButton = wrap.querySelector("[data-embed-restart]");
    const panel = wrap.closest(".play-panel");
    const keyboard = panel?.querySelector("[data-game-keyboard]");

    const focusGame = () => {
      window.setTimeout(() => {
        iframe?.focus();
        iframe?.contentWindow?.focus();
      }, 150);
    };

    loader?.addEventListener("click", () => {
      if (iframe && iframe.dataset.src && !iframe.src) {
        iframe.src = iframe.dataset.src;
      }
      wrap.classList.add("is-loaded");
      if (fullscreenButton) fullscreenButton.hidden = false;
      if (restartButton) restartButton.hidden = false;
      if (keyboard && isTouchDevice) keyboard.hidden = false;
      focusGame();
    });

    // Restart: reload the game build from scratch (works for every game without
    // needing an in-game restart key).
    restartButton?.addEventListener("click", () => {
      if (iframe && iframe.dataset.src) {
        iframe.src = iframe.dataset.src;
        focusGame();
      }
    });

    fullscreenButton?.addEventListener("click", () => {
      if (document.fullscreenElement) {
        document.exitFullscreen?.();
      } else {
        wrap.requestFullscreen?.();
      }
    });
  });

  document.querySelectorAll("[data-game-keyboard]").forEach((keyboard) => {
    if (!isTouchDevice) {
      keyboard.style.display = "none";
      return;
    }

    const playPanel = keyboard.closest(".play-panel");
    const iframe = playPanel?.querySelector("[data-play-embed]");

    keyboard.querySelector("[data-focus-game]")?.addEventListener("click", () => {
      iframe?.focus();
      iframe?.contentWindow?.focus();
    });

    keyboard.querySelectorAll("[data-key]").forEach((button) => {
      const key = button.dataset.key;
      if (!key) return;

      const press = (event) => {
        event.preventDefault();
        button.setPointerCapture?.(event.pointerId);
        fireGameKey(iframe, key, "keydown");
      };

      const release = (event) => {
        event.preventDefault();
        fireGameKey(iframe, key, "keyup");
      };

      button.addEventListener("pointerdown", press);
      button.addEventListener("pointerup", release);
      button.addEventListener("pointercancel", release);
      button.addEventListener("pointerleave", release);
    });
  });

  document.querySelectorAll("[data-source-card]").forEach((card) => {
    card.addEventListener("toggle", async () => {
      if (!card.open || card.dataset.loaded === "true") return;
      const code = card.querySelector("[data-source-code]");
      code.textContent = "Loading source...";
      try {
        const response = await fetch(card.dataset.sourceUrl);
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        code.textContent = await response.text();
        card.dataset.loaded = "true";
      } catch (error) {
        console.error(error);
        code.textContent = "Source file could not be loaded.";
      }
    });
  });
</script>
